# Copy this file to .env and fill in values before running

# --- Database ---
POSTGRES_PASSWORD=changeme_in_production
PG_PORT=5432

# Connection string (auto-constructed if not set)
# DATABASE_URL=postgresql://context_graph:changeme@localhost:5432/context_graph_db

# --- Embeddings ---
# Choose embedding provider: openai | mock
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIM=1536

# Required if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...

# --- LLM (entity extraction) ---
# Uses Anthropic Claude for LLM-based entity extraction
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Ingestion ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50
INGESTION_BATCH_SIZE=32
